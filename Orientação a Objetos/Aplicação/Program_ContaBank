package Aplication;

import java.util.Locale;
import java.util.Scanner;

import Entidade.ClienteBank;

public class Program_ContaBank {
	public static void main(String[] args) {
		Locale.setDefault(Locale.US);
		Scanner sc = new Scanner(System.in);
		ClienteBank cliente = new ClienteBank();
		System.out.println("Entre com o número da conta: ");
		int number = sc.nextInt();
		System.out.println("Entre com o nome do cliente: ");
		sc.nextLine();
		String name = sc.nextLine();
		
		System.out.println("Deseja iniciar a conta com um depósito inicial (s/n)?");
		char letra = sc.next().charAt(0);
		System.out.println();
		if (letra == 's') {
			System.out.println("Qual valor do depósito?");
			double montain = sc.nextDouble();
			cliente = new ClienteBank(name, number, montain);
			System.out.println("Atualização dos dados: " + cliente);
		}
		else {
			cliente = new ClienteBank(name, number);
			System.out.println("Atualização dos dados: " + cliente);
		}
		
		System.out.println("Entre com um valor de depósito: ");
		double montain = sc.nextDouble();
		cliente.deposit(montain);
		System.out.println("Atualização dos dados: " + cliente);
		System.out.println();
		System.out.println("Entre com um valor de saque: ");
		montain = sc.nextDouble();
		cliente.saque(montain);
		System.out.println("Atualização dos dados: " + cliente);
		sc.close();
	}
}
