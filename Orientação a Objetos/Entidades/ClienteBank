package Entidade;

public class ClienteBank {
	private String name;
	private int number;
	private double montain;
	
	public ClienteBank() {
		
	}
	public ClienteBank(String name, int number, double montain) {
		this.name = name;
		this.number = number;
		this.montain = montain;
	}
	public ClienteBank(String name, int number) {
		this.name = name;
		this.number = number;
	}
	public String getName() {
		return name;
	}
	public void setName(String name) {
		this.name = name;
	}
	public int getNumber() {
		return number;
	}
	public double getMontain() {
		return montain;
	}
	public void deposit (double montain ) {
		this.montain += montain;
	}
	public void saque(double montain) {
		this.montain -= montain + 5.00;
	}
	public String toString() {
		return "Nome: "
				+ name
				+ ", "
				+ "Número da conta: "
				+ number
				+ " "
				+ String.format("Saldo: R$ %.2f", getMontain());
	}
}
