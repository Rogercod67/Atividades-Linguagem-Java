package Entidade;

public class Alunos {
	public String name;
	public double nota1;
	public double nota2;
	public double nota3;
	
	public double notaFinal() {
		return nota1 + nota2 + nota3;
	}
	public double missing() {
		return 60 - notaFinal();
	}
	public String aprov() {
		if (notaFinal() > 60) {
			return "\n"
					+ "PASS";
		}
		else {
			return "\n"
					+"FAILD"
					+ "\n"
					+ String.format("MISSING %.2f POINTS", missing());
		}
	}
	public String toString() {
		return "Nome: "
				+ name
				+ "\n"
				+ String.format("Grade final = %.2f", notaFinal())
				+ aprov();
	}
	
}
