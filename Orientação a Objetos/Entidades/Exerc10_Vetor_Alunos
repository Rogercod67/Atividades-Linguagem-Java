package Entidade;

public class Vetor_Alunos {
	private String name;
	private double nota1;
	private double nota2;
	
	public Vetor_Alunos() {
		
	}
	public Vetor_Alunos(String name, double nota1, double nota2) {
		this.name = name;
		this.nota1 = nota1;
		this.nota2 = nota2;
	}

	public String getName() {
		return name;
	}

	public double getNota1() {
		return nota1;
	}

	public void setNota1(double nota1) {
		this.nota1 = nota1;
	}

	public double getNota2() {
		return nota2;
	}

	public void setNota2(double nota2) {
		this.nota2 = nota2;
	}
	
	public double media() {
		return (nota1 + nota2)/2.0; 
	}
	
}
